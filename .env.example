# Public site URL — used for metadata, canonical links, and Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB connection string — required for the Contact form's Server Action
# (src/app/(marketing)/contact/actions.ts) to persist a Lead. Never exposed
# to the client (no NEXT_PUBLIC_ prefix) — see src/lib/db.ts.
MONGODB_URI=mongodb://localhost:27017/hubzero

# Auth.js session-signing secret — required for /studio. Generate with
# `npx auth secret` (at least 32 characters). See src/lib/env.ts and
# src/lib/cms/auth.ts.
AUTH_SECRET=

# Cloudinary — the production media storage backend (src/lib/cms/storage).
# All three are required together; if any is missing, media uploads fall
# back to local disk storage automatically (src/lib/cms/storage/index.ts) —
# useful for local development, never intended for production. Get these
# from https://console.cloudinary.com (Dashboard → Product Environment
# Credentials).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Shared secret the scheduled-publishing cron job authenticates with when it
# calls POST /api/cron/process-schedule (src/app/api/cron/process-schedule/route.ts).
# See docs/operations/SCHEDULED_PUBLISHING.md. Generate the same way as
# AUTH_SECRET; the route refuses every request if this is unset.
CRON_SECRET=

# Auth.js only trusts the incoming request's Host header automatically when
# NODE_ENV !== "production" (or on Vercel/Cloudflare Pages, which set their
# own trust signal). This app is self-hosted via the Dockerfile/standalone
# output (README "Docker" section), so neither applies — without this,
# every /api/auth/* request in a production build (a local `npm run start`,
# `node .next/standalone/server.js`, or the real deployment) fails with
# Auth.js's "UntrustedHost" error. Safe to enable here because the
# deployment topology (Cloudflare/NGINX in front, per
# ARCHITECTURE/08_TECHNICAL_ARCHITECTURE.md §8) only ever forwards traffic
# for HubZero's own domain — see https://authjs.dev/reference/core#trusthost.
AUTH_TRUST_HOST=true
