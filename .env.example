# Public site URL — used for metadata, canonical links, and Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB connection string — required for the Contact form's Server Action
# (src/app/(marketing)/contact/actions.ts) to persist a Lead. Never exposed
# to the client (no NEXT_PUBLIC_ prefix) — see src/lib/db.ts.
MONGODB_URI=mongodb://localhost:27017/hubzero

# Auth.js session-signing secret — required for /studio. Generate with
# `npx auth secret` (at least 32 characters). See src/lib/env.ts and
# src/lib/cms/auth.ts.
AUTH_SECRET=
