# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site URL — used for metadata, canonical links, Open Graph tags, and sitemaps.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
MONGODB_URI=

# Auth.js (CMS session signing)
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Cloudinary (media storage — see src/lib/media/cloudinary.ts)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI provider (Gemini today — see src/lib/ai)
GEMINI_API_KEY=
