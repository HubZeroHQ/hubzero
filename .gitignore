# ------------------------------
# Root-Level .gitignore for HubZero-Next
# ------------------------------

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/

# Logs
logs
*.log
*.log.*

# System Files
.DS_Store
Thumbs.db

# Environment Variables
.env
.env.*.local
.env.local
.env.development.local
.env.production.local
.env.test.local

# OS Metadata
*.swp
.swp
*.swo

# IDE/Editor Configs
.vscode/
.idea/
*.code-workspace

# Next.js
.next/
out/
next-env.d.ts

# Shell
deploy.sh
*.sh~

# Local Testing
coverage/
*.local

# Firebase (if used later)
.firebase/
.firebaserc

# Misc
*.pem
*.key
*.crt
*.cert

# Static Assets Cache
.cache/

.mcp.json

tsconfig.tsbuildinfo

.codex/

# Local-only seed source (uploaded to Cloudinary by scripts/seed-engineering-profiles.ts;
# Cloudinary is the only place media binaries live — see lib/media/cloudinary.ts).
/team-portraits/

# Pre-delete/pre-rename backups written by one-off data migration scripts
# under scripts/ before they modify production records — real production
# data, never committed.
/scripts/backups/