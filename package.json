{
  "name": "hubzero",
  "version": "0.1.0",
  "private": true,
  "description": "HubZero v2 — engineering studio marketing site and CMS.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "tsx scripts/copy-standalone-assets.ts",
    "start": "node --env-file=.env.local .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "create-admin": "tsx --env-file=.env.local scripts/create-admin.ts",
    "migrate-content": "tsx --env-file=.env.local scripts/migrate-content.ts",
    "migrate-content-blocks": "tsx --env-file=.env.local scripts/migrate-content-blocks.ts",
    "migrate-media-to-cloudinary": "tsx --env-file=.env.local scripts/migrate-media-to-cloudinary.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-switch": "^1.3.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "mongoose": "^9.7.3",
    "motion": "^12.42.2",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
